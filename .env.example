# ─────────────────────────────────────────────────────────────
# Smart Attendance — environment example (copy to .env)
# ─────────────────────────────────────────────────────────────

# ─── API (apps/api) ─────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
API_BASE_URL=http://localhost:3000

# PostgreSQL
POSTGRES_USER=sa_user
POSTGRES_PASSWORD=sa_password_change_me
POSTGRES_DB=smart_attendance
POSTGRES_PORT=5432
# Prisma reads DATABASE_URL. Host = 'postgres' inside docker-compose, 'localhost' for dev outside.
DATABASE_URL=postgresql://sa_user:sa_password_change_me@localhost:5432/smart_attendance?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=replace-with-32-byte-random-hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-with-another-32-byte-random-hex
JWT_REFRESH_TTL=7d

# CORS — comma-separated allowed origins (required for credentialed requests)
ALLOWED_ORIGINS=http://localhost:3100,http://localhost:8081,http://localhost:19006

# Rate limit
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_CHECKIN_PER_MINUTE=10

# Zero-tap (Day 5)
ZERO_TAP_NONCE_WINDOW_SECONDS=90
PLAY_INTEGRITY_PROJECT_NUMBER=
APP_ATTEST_TEAM_ID=

# ─── Portal (apps/portal) ───────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# ─── Mobile (apps/mobile) ───────────────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
